{
  "name": "@laserfiche/lf-repository-api-client",
  "type": "module",
  "version": "1.0.0",
  "description": "The TypeScript Laserfiche Repository API Client library for accessing the v1 Laserfiche Repository APIs.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/index.js",
    "dist/index.d.ts",
    "README.md"
  ],
  "scripts": {
    "lint": "NODE_OPTIONS='--import tsx' eslint .",
    "test:unit": "echo 'No unit tests in this package'",
    "test:browser": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPatterns='\\.integration\\.test\\.ts$' --rootDir=test --config jest.jsdom.config.ts --runInBand",
    "test:node": "node --experimental-vm-modules --experimental-fetch node_modules/jest/bin/jest.js --testPathPatterns='\\.integration\\.test\\.ts$' --rootDir=test --config jest.node.config.ts --runInBand",
    "build": "npm run nswag && npm run clean && tsc -b",
    "build:watch": "npm run nswag && tsc -b --watch",
    "clean": "tsc -b --clean",
    "nswag": "nswag run generate-client/nswag.json",
    "postpublish": "git tag lf-repository-api-client-v1-v$npm_package_version && git push --tags"
  },
  "keywords": [
    "Laserfiche"
  ],
  "author": "Laserfiche",
  "url": "https://www.laserfiche.com/",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Laserfiche/lf-api-js"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/isomorphic-fetch": "^0.0.39",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.3",
    "dotenv": "^17.2.3",
    "isomorphic-fetch": "^3.0.0",
    "jest": "^30.2.0",
    "jest-junit": "^16.0.0",
    "nswag": "^14.6.3",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.52.0"
  },
  "dependencies": {
    "@laserfiche/lf-api-client-core": "workspace:^",
    "@laserfiche/lf-js-utils": "workspace:^"
  }
}