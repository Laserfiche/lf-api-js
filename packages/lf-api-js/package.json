{
  "name": "@laserfiche/lf-api-js",
  "version": "1.0.0",
  "description": "The JavaScript Laserfiche API Client library for accessing available Laserfiche APIs.",
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "type": "module",
  "files": [
    "cdn",
    "dist",
    "!dist/rollup.*",
    "README.md"
  ],
  "keywords": [
    "Laserfiche"
  ],
  "author": "Laserfiche",
  "url": "https://www.laserfiche.com/",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Laserfiche/lf-api-js"
  },
  "scripts": {
    "lint": "NODE_OPTIONS='--import tsx' eslint .",
    "build": "npm run clean && tsc -b && npm run generate-esm-module && npm run generate-types",
    "clean": "tsc -b --clean",
    "generate-esm-module": "npx rollup -c",
    "generate-types": "api-extractor run --local",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --rootDir=test --config jest.node.config.ts --runInBand",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPatterns='\\.unit\\.test\\.ts$' --rootDir=test --config jest.node.config.ts --runInBand",
    "postpublish": "git tag lf-api-js-v$npm_package_version && git push --tags"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@microsoft/api-extractor": "^7.55.2",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.3",
    "jest": "^30.2.0",
    "jest-junit": "^16.0.0",
    "rollup": "^4.55.1",
    "ts-jest": "^29.2.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.52.0"
  },
  "dependencies": {
    "@laserfiche/lf-api-client-core": "workspace:^",
    "@laserfiche/lf-js-utils": "workspace:^",
    "@laserfiche/lf-repository-api-client": "workspace:^",
    "@laserfiche/lf-repository-api-client-v2": "workspace:^"
  }
}