  "repository": {
    "type": "git",
    "url": "https://github.com/Laserfiche/lf-api-js"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^5.19.0",
    "@typescript-eslint/parser": "^5.19.0",
    "eslint": "^8.13.0",
    "isomorphic-fetch": "^3.0.0",
    "jsdom": "^25.0.0",
    "ts-node": "^10.4.0",
    "tslib": "^2.3.1",
    "typescript": "^4.5.4",
    "vitest": "^4.1.6"
  }
}
